<Window x:Class="Sailock.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Sailock.ViewModels"
        Icon="/Resources/sailock.ico"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResize"
        BorderThickness="0"
        BorderBrush="Transparent"
        Background="#000000"
        Title="Sailock"
        Height="720"
        Width="1280"
        MinHeight="500"
        MinWidth="900">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TopBar -->
        <Grid Grid.Row="0"
              Background="#0A0A0A"
              MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="SAILOCK"
                       Foreground="#333333"
                       FontFamily="/Fonts/#Supermolot Light"
                       FontSize="11"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"
                       Grid.Column="0"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="BtnMinimize" Content="─" Width="46" Height="32"
                        Click="BtnMinimize_Click" Style="{StaticResource WindowControlButton}"/>
                <Button x:Name="BtnMaximize" Content="□" Width="46" Height="32"
                        Click="BtnMaximize_Click" Style="{StaticResource WindowControlButton}"/>
                <Button x:Name="BtnClose"    Content="✕" Width="46" Height="32"
                        Click="BtnClose_Click" Style="{StaticResource WindowControlButton_Close}"/>
            </StackPanel>
        </Grid>

        <!-- Área principal -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0"
                    Width="220"
                    Background="#0A0A0A"
                    BorderBrush="#1A1A1A"
                    BorderThickness="0,0,1,0"
                    Visibility="{Binding SidebarVisibility}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Logo -->
                    <Image Grid.Row="0" Height="55" Margin="30,28,30,32"
                           Source="{Binding LogoSource}"/>

                    <!-- Navegación -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Top">
                        <Button Content="{DynamicResource Nav_Dashboard}"
                                Style="{StaticResource SidebarButton}"
                                Command="{Binding NavigateDashboardCommand}"/>
                        <Button Content="{DynamicResource Nav_Generator}"
                                Style="{StaticResource SidebarButton}"
                                Command="{Binding NavigateGeneratorCommand}"/>
                        <Button Content="{DynamicResource Nav_Settings}"
                                Style="{StaticResource SidebarButton}"
                                Command="{Binding NavigateSettingsCommand}"/>
                    </StackPanel>

                    <!-- Logout + versión -->
                    <StackPanel Grid.Row="2" Margin="20,0,20,20">
                        <Button Content="{DynamicResource Nav_Logout}"
                                Style="{StaticResource SailockButton}"
                                Command="{Binding LogoutCommand}"
                                Margin="0,0,0,10"/>
                        <Button Content="v1.1.3"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#555555"
                                FontSize="10"
                                FontFamily="/Fonts/#Supermolot Light"
                                HorizontalAlignment="Center"
                                Cursor="Arrow"
                                Height="Auto"
                                Padding="0"
                                Margin="0,5,0,0"
                                Command="{Binding ShowChangelogCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Contenido -->
            <ContentControl Grid.Column="1" Content="{Binding CurrentView}">
                <ContentControl.LayoutTransform>
                    <ScaleTransform ScaleX="{DynamicResource GlobalScale}"
                                    ScaleY="{DynamicResource GlobalScale}"/>
                </ContentControl.LayoutTransform>
            </ContentControl>
        </Grid>
    </Grid>
</Window>