<UserControl x:Class="Sailock.Views.ChangelogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource AppBackground}">

    <Grid Margin="32,28,32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Cabecera -->
        <Grid Grid.Row="0" Margin="0,0,0,28">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{DynamicResource Changelog_Title}"
                               Foreground="{DynamicResource AppForeground}"
                               FontFamily="/Fonts/#Supermolot Light"
                               FontSize="36"/>
                    <TextBlock Text="{Binding CurrentVersion}"
                               Foreground="{DynamicResource AppAccent}"
                               FontFamily="/Fonts/#Supermolot Light"
                               FontSize="20"
                               VerticalAlignment="Bottom"
                               Margin="14,0,0,6"/>
                </StackPanel>
                <TextBlock Text="{DynamicResource Changelog_Subtitle}"
                           Foreground="{DynamicResource AppForegroundDim}"
                           FontFamily="/Fonts/#Supermolot Light"
                           FontSize="11"
                           Margin="0,6,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Lista de versiones -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Style="{StaticResource SailockScrollViewer}">
            <ItemsControl ItemsSource="{Binding Entries}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{DynamicResource ContrastBorderBrush}"
                                BorderThickness="{DynamicResource ContrastBorderThickness}"
                                Margin="0,0,0,16"
                                Padding="24,20">
                            <StackPanel>

                                <!-- Header versión -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{DynamicResource Changelog_VersionPrefix}"
                                                       Foreground="{DynamicResource AppAccent}"
                                                       FontFamily="/Fonts/#Supermolot Light"
                                                       FontSize="18"/>
                                            <TextBlock Text="{Binding Version}"
                                                       Foreground="{DynamicResource AppAccent}"
                                                       FontFamily="/Fonts/#Supermolot Light"
                                                       FontSize="18"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Date}"
                                                   Foreground="{DynamicResource AppForegroundDim}"
                                                   FontFamily="/Fonts/#Supermolot Light"
                                                   FontSize="11"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <!-- Badge LATEST / LEGACY — se mantiene en inglés -->
                                    <Border Grid.Column="1"
                                            VerticalAlignment="Top"
                                            Padding="10,4"
                                            CornerRadius="2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background"      Value="#1A1A1A"/>
                                                <Setter Property="BorderBrush"     Value="#333333"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLatest}" Value="True">
                                                        <Setter Property="Background"  Value="#1A2A1A"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AppAccent}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontFamily="/Fonts/#Supermolot Light" FontSize="10">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text"       Value="LEGACY"/>
                                                    <Setter Property="Foreground" Value="#555555"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsLatest}" Value="True">
                                                            <Setter Property="Text"       Value="LATEST"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource AppAccent}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </Grid>

                                <!-- NEW FEATURES -->
                                <StackPanel Margin="0,0,0,12"
                                            Visibility="{Binding Added, Converter={StaticResource CountToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="★"
                                                   Foreground="{DynamicResource AppAccent}"
                                                   FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="{DynamicResource Changelog_NewFeatures}"
                                                   Foreground="{DynamicResource AppForeground}"
                                                   FontFamily="/Fonts/#Supermolot Light"
                                                   FontSize="12" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ItemsControl ItemsSource="{Binding Added}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                                    <TextBlock Text="* "
                                                               Foreground="{DynamicResource AppForegroundDim}"
                                                               FontFamily="/Fonts/#Supermolot Light" FontSize="11"/>
                                                    <TextBlock Text="{Binding}"
                                                               Foreground="{DynamicResource AppForegroundDim}"
                                                               FontFamily="/Fonts/#Supermolot Light"
                                                               FontSize="11" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <!-- IMPROVEMENTS -->
                                <StackPanel Margin="0,0,0,12"
                                            Visibility="{Binding Changed, Converter={StaticResource CountToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="⚙"
                                                   Foreground="#00ab26"
                                                   FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="{DynamicResource Changelog_Improvements}"
                                                   Foreground="{DynamicResource AppForeground}"
                                                   FontFamily="/Fonts/#Supermolot Light"
                                                   FontSize="12" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ItemsControl ItemsSource="{Binding Changed}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                                    <TextBlock Text="* "
                                                               Foreground="{DynamicResource AppForegroundDim}"
                                                               FontFamily="/Fonts/#Supermolot Light" FontSize="11"/>
                                                    <TextBlock Text="{Binding}"
                                                               Foreground="{DynamicResource AppForegroundDim}"
                                                               FontFamily="/Fonts/#Supermolot Light"
                                                               FontSize="11" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <!-- BUG FIXES -->
                                <StackPanel Visibility="{Binding Fixed, Converter={StaticResource CountToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="✦"
                                                   Foreground="#FF4D4D"
                                                   FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="{DynamicResource Changelog_BugFixes}"
                                                   Foreground="{DynamicResource AppForeground}"
                                                   FontFamily="/Fonts/#Supermolot Light"
                                                   FontSize="12" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ItemsControl ItemsSource="{Binding Fixed}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                                    <TextBlock Text="* "
                                                               Foreground="{DynamicResource AppForegroundDim}"
                                                               FontFamily="/Fonts/#Supermolot Light" FontSize="11"/>
                                                    <TextBlock Text="{Binding}"
                                                               Foreground="{DynamicResource AppForegroundDim}"
                                                               FontFamily="/Fonts/#Supermolot Light"
                                                               FontSize="11" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Botón volver -->
        <Button Grid.Row="2"
                Content="{DynamicResource Changelog_Back}"
                Width="140"
                HorizontalAlignment="Left"
                Style="{StaticResource SailockButton}"
                Command="{Binding CloseCommand}"
                Margin="0,16,0,0"/>
    </Grid>
</UserControl>