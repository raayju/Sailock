<UserControl x:Class="Sailock.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Sailock.Views"
             Background="{DynamicResource AppBackground}">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Style="{StaticResource SailockScrollViewer}">
            <StackPanel Margin="32,28,32,28">

                <TextBlock Text="{DynamicResource Settings_Title}"
                           Foreground="{DynamicResource AppForeground}"
                           FontFamily="/Fonts/#JetBrains Mono"
                           FontSize="28"
                           Margin="0,0,0,24"/>

                <!-- SECURITY -->
                <Border BorderBrush="{DynamicResource ContrastBorderBrush}"
        BorderThickness="{DynamicResource ContrastBorderThickness}"
        Margin="0,0,0,20"
        Background="{DynamicResource AppSurface}">
                    <StackPanel>

                        <TextBlock Text="{DynamicResource Settings_Security}"
                   Foreground="{DynamicResource AppForegroundDim}"
                   FontFamily="/Fonts/#JetBrains Mono"
                   FontSize="11"
                   Margin="16,10,16,10"/>

                        <Rectangle Height="1" Fill="{DynamicResource ContrastSeparatorBrush}"/>

                        <!-- 2FA -->
                        <Grid Margin="16,16,16,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource Settings_2FA_Title}"
                           Foreground="{DynamicResource AppForeground}"
                           FontFamily="/Fonts/#JetBrains Mono"
                           FontSize="13"/>
                                <TextBlock Text="{DynamicResource Settings_2FA_Desc}"
                           Foreground="{DynamicResource AppForegroundDim}"
                           FontFamily="/Fonts/#JetBrains Mono"
                           FontSize="10"
                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Width="110"
                    Style="{StaticResource SailockButton}"
                    Command="{Binding Enable2FACommand}">
                                <Button.Content>
                                    <TextBlock FontFamily="/Fonts/#JetBrains Mono" FontSize="12">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{DynamicResource Settings_2FA_Enable}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Is2FAEnabled}" Value="True">
                                                        <Setter Property="Text" Value="{DynamicResource Settings_2FA_Disable}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button.Content>
                            </Button>
                        </Grid>

                        <Rectangle Height="1" Fill="{DynamicResource ContrastSeparatorBrush}"/>

                        <!-- Change Master Password -->
                        <Grid Margin="16,16,16,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource Settings_MasterPass_Title}"
                           Foreground="{DynamicResource AppForeground}"
                           FontFamily="/Fonts/#JetBrains Mono"
                           FontSize="13"/>
                                <TextBlock Text="{DynamicResource Settings_MasterPass_Desc}"
                           Foreground="{DynamicResource AppForegroundDim}"
                           FontFamily="/Fonts/#JetBrains Mono"
                           FontSize="10"
                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                    Content="{DynamicResource Settings_MasterPass_Button}"
                    Width="110"
                    Style="{StaticResource SailockButton}"
                    Command="{Binding OpenChangeMasterPasswordCommand}"/>
                        </Grid>

                        <Rectangle Height="1" Fill="{DynamicResource ContrastSeparatorBrush}"/>

                        <!-- Auto-Lock -->
                        <Grid Margin="16,16,16,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource Settings_AutoLock_Title}"
                                           Foreground="White"
                                           FontFamily="/Fonts/#JetBrains Mono"
                                           FontSize="13"/>
                                <TextBlock Text="{DynamicResource Settings_AutoLock_Desc}"
                                           Foreground="#444444"
                                           FontFamily="/Fonts/#JetBrains Mono"
                                           FontSize="10"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1"
                                      Width="110"
                                      Style="{StaticResource SailockComboBox}"
                                      ItemsSource="{x:Static local:SettingsView.AutoLockOptions}"
                                      SelectedItem="{Binding SelectedAutoLockTimeout, Mode=TwoWay}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ACCESSIBILITY -->
                <Border BorderBrush="{DynamicResource ContrastBorderBrush}"
        BorderThickness="{DynamicResource ContrastBorderThickness}"
        Margin="0,0,0,20"
        Background="{DynamicResource AppSurface}">
                    <StackPanel>

                        <TextBlock Text="{DynamicResource Settings_Accessibility}"
                   Foreground="{DynamicResource AppForegroundDim}"
                   FontFamily="/Fonts/#JetBrains Mono"
                   FontSize="11"
                   Margin="16,10,16,10"/>

                        <Rectangle Height="1" Fill="{DynamicResource ContrastSeparatorBrush}"/>

                        <!-- Theme -->
                        <Grid Margin="16,16,16,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource Settings_Theme_Title}"
                           Foreground="{DynamicResource AppForeground}"
                           FontFamily="/Fonts/#JetBrains Mono"
                           FontSize="13"/>
                                <TextBlock Text="{DynamicResource Settings_Theme_Desc}"
                           Foreground="{DynamicResource AppForegroundDim}"
                           FontFamily="/Fonts/#JetBrains Mono"
                           FontSize="10"
                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox Content="{DynamicResource Settings_Theme_Light}"
                          IsChecked="{Binding IsDarkTheme, Converter={StaticResource InverseBoolConverter}}"
                          Style="{StaticResource SailockCheckBox}"
                          Margin="0,0,16,0"/>
                                <CheckBox Content="{DynamicResource Settings_Theme_Dark}"
                          IsChecked="{Binding IsDarkTheme}"
                          Style="{StaticResource SailockCheckBox}"/>
                            </StackPanel>
                        </Grid>

                        <Rectangle Height="1" Fill="{DynamicResource ContrastSeparatorBrush}"/>

                        <!-- Contrast -->
                        <Grid Margin="16,16,16,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource Settings_Contrast_Title}"
                           Foreground="{DynamicResource AppForeground}"
                           FontFamily="/Fonts/#JetBrains Mono"
                           FontSize="13"/>
                                <TextBlock Text="{DynamicResource Settings_Contrast_Desc}"
                           Foreground="{DynamicResource AppForegroundDim}"
                           FontFamily="/Fonts/#JetBrains Mono"
                           FontSize="10"
                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox Content="{DynamicResource Settings_Contrast_On}"
                          IsChecked="{Binding IsHighContrast}"
                          Style="{StaticResource SailockCheckBox}"
                          Margin="0,0,16,0"/>
                                <CheckBox Content="{DynamicResource Settings_Contrast_Off}"
                          IsChecked="{Binding IsHighContrast, Converter={StaticResource InverseBoolConverter}}"
                          Style="{StaticResource SailockCheckBox}"/>
                            </StackPanel>
                        </Grid>

                        <Rectangle Height="1" Fill="{DynamicResource ContrastSeparatorBrush}"/>

                        <!-- Text Size -->
                        <Grid Margin="16,16,16,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource Settings_TextSize_Title}"
                           Foreground="{DynamicResource AppForeground}"
                           FontFamily="/Fonts/#JetBrains Mono"
                           FontSize="13"/>
                                <TextBlock Text="{DynamicResource Settings_TextSize_Desc}"
                           Foreground="{DynamicResource AppForegroundDim}"
                           FontFamily="/Fonts/#JetBrains Mono"
                           FontSize="10"
                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1"
                      SelectedItem="{Binding SelectedTextSize, Mode=TwoWay}"
                      Width="160"
                      Style="{StaticResource SailockComboBox}"
                      ItemsSource="{x:Static local:SettingsView.TextSizeOptions}"/>
                        </Grid>

                        <Rectangle Height="1" Fill="{DynamicResource ContrastSeparatorBrush}"/>

                        <!-- Language -->
                        <Grid Margin="16,16,16,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource Settings_Language_Title}"
                           Foreground="{DynamicResource AppForeground}"
                           FontFamily="/Fonts/#JetBrains Mono"
                           FontSize="13"/>
                                <TextBlock Text="{DynamicResource Settings_Language_Desc}"
                           Foreground="{DynamicResource AppForegroundDim}"
                           FontFamily="/Fonts/#JetBrains Mono"
                           FontSize="10"
                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1"
                      SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                      Width="160"
                      Style="{StaticResource SailockComboBox}"
                      ItemsSource="{x:Static local:SettingsView.LanguageOptions}"/>
                        </Grid>

                    </StackPanel>
                </Border>

                <!-- DATA MANAGEMENT -->
                <Border BorderBrush="{DynamicResource ContrastBorderBrush}"
        BorderThickness="{DynamicResource ContrastBorderThickness}"
        Margin="0,0,0,20"
        Background="{DynamicResource AppSurface}">
                    <StackPanel>

                        <TextBlock Text="{DynamicResource Settings_DataManagement}"
                   Foreground="{DynamicResource AppForegroundDim}"
                   FontFamily="/Fonts/#JetBrains Mono"
                   FontSize="11"
                   Margin="16,10,16,10"/>

                        <Rectangle Height="1" Fill="{DynamicResource ContrastSeparatorBrush}"/>

                        <TextBlock Text="{Binding StatusMessage}"
                   Foreground="{DynamicResource AppAccent}"
                   FontFamily="/Fonts/#JetBrains Mono"
                   FontSize="11"
                   Margin="16,12,16,0"
                   TextWrapping="Wrap"
                   Visibility="{Binding StatusMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

                        <!-- Import -->
                        <Grid Margin="16,16,16,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource Settings_Import_Title}"
                           Foreground="{DynamicResource AppForeground}"
                           FontFamily="/Fonts/#JetBrains Mono"
                           FontSize="13"/>
                                <TextBlock Text="{DynamicResource Settings_Import_Desc}"
                           Foreground="{DynamicResource AppForegroundDim}"
                           FontFamily="/Fonts/#JetBrains Mono"
                           FontSize="10"
                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                    Content="{DynamicResource Settings_Import_Button}"
                    Width="110"
                    Style="{StaticResource SailockButton}"
                    Command="{Binding ImportCommand}"/>
                        </Grid>

                        <Rectangle Height="1" Fill="{DynamicResource ContrastSeparatorBrush}"/>

                        <!-- Export -->
                        <Grid Margin="16,16,16,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource Settings_Export_Title}"
                           Foreground="{DynamicResource AppForeground}"
                           FontFamily="/Fonts/#JetBrains Mono"
                           FontSize="13"/>
                                <TextBlock Text="{DynamicResource Settings_Export_Desc}"
                           Foreground="{DynamicResource AppForegroundDim}"
                           FontFamily="/Fonts/#JetBrains Mono"
                           FontSize="10"
                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                    Content="{DynamicResource Settings_Export_Button}"
                    Width="110"
                    Style="{StaticResource SailockButton}"
                    Command="{Binding ExportCommand}"/>
                        </Grid>

                    </StackPanel>
                </Border>

                <!-- DANGER ZONE -->
                <Border BorderBrush="#2A0000" BorderThickness="1" Margin="0,0,0,20"
        Background="{DynamicResource AppSurface}">
                    <StackPanel>

                        <TextBlock Text="{DynamicResource Settings_DangerZone}"
                   Foreground="#663333"
                   FontFamily="/Fonts/#JetBrains Mono"
                   FontSize="11"
                   Margin="16,10,16,10"/>

                        <Rectangle Height="1" Fill="#2A0000"/>

                        <!-- Delete All -->
                        <Grid Margin="16,16,16,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource Settings_DeleteAll_Title}"
                           Foreground="#FF4D4D"
                           FontFamily="/Fonts/#JetBrains Mono"
                           FontSize="13"/>
                                <TextBlock Text="{DynamicResource Settings_DeleteAll_Desc}"
                           Foreground="#663333"
                           FontFamily="/Fonts/#JetBrains Mono"
                           FontSize="10"
                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                    Content="{DynamicResource Settings_DeleteAll_Button}"
                    Width="110"
                    Style="{StaticResource SailockButton_Danger}"
                    Command="{Binding OpenDeleteModalCommand}"/>
                        </Grid>

                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Modal Delete All -->
        <Grid Visibility="{Binding IsDeleteModalOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.LayoutTransform>
                <ScaleTransform ScaleX="{DynamicResource GlobalScaleInverse}"
                    ScaleY="{DynamicResource GlobalScaleInverse}"/>
            </Grid.LayoutTransform>
            <Rectangle Fill="#000000" Opacity="0.75"/>
            <Border Background="#111111" BorderBrush="#FF4D4D" BorderThickness="1"
            Width="460" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="36,30">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Modal_DeleteAll_Title}"
                       Foreground="White" FontFamily="/Fonts/#JetBrains Mono"
                       FontSize="18"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"/>
                    <TextBlock Text="{DynamicResource Modal_DeleteAll_Warning}"
                       Foreground="#FF4D4D" FontFamily="/Fonts/#JetBrains Mono"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,0,0,20"/>
                    <TextBlock Text="{DynamicResource Modal_DeleteAll_Confirm}"
                       Foreground="#888888" FontFamily="/Fonts/#JetBrains Mono"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,0,0,28"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="{DynamicResource Modal_Delete}"
                        Width="120" Style="{StaticResource SailockButton_Danger}"
                        Command="{Binding ConfirmDeleteCommand}"
                        Margin="0,0,16,0"/>
                        <Button Content="{DynamicResource Modal_Cancel}"
                        Width="120" Style="{StaticResource SailockButton}"
                        Command="{Binding CancelDeleteCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Modal Disable 2FA -->
        <Grid Visibility="{Binding IsDisable2FAModalOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.LayoutTransform>
                <ScaleTransform ScaleX="{DynamicResource GlobalScaleInverse}"
                    ScaleY="{DynamicResource GlobalScaleInverse}"/>
            </Grid.LayoutTransform>
            <Rectangle Fill="#000000" Opacity="0.75"/>
            <Border Background="#111111" BorderBrush="#00ab26" BorderThickness="1"
            Width="420" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="36,30">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Modal_Disable2FA_Title}"
                       Foreground="White" FontFamily="/Fonts/#JetBrains Mono"
                       FontSize="18"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"/>
                    <TextBlock Text="{DynamicResource Modal_Disable2FA_Desc}"
                       Foreground="#888888" FontFamily="/Fonts/#JetBrains Mono"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,0,0,20"/>
                    <TextBlock Text="{DynamicResource Modal_Disable2FA_Warning}"
                       Foreground="#FF4D4D" FontFamily="/Fonts/#JetBrains Mono"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,0,0,28"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="{DynamicResource Modal_Disable2FA_Button}"
                        Width="130" Style="{StaticResource SailockButton_Danger}"
                        Command="{Binding ConfirmDisable2FACommand}"
                        Margin="0,0,16,0"/>
                        <Button Content="{DynamicResource Modal_Cancel}"
                        Width="130" Style="{StaticResource SailockButton}"
                        Command="{Binding CancelDisable2FACommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- Modal Change Master Password -->
        <Grid Visibility="{Binding IsChangeMasterPasswordModalOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.LayoutTransform>
                <ScaleTransform ScaleX="{DynamicResource GlobalScaleInverse}"
            ScaleY="{DynamicResource GlobalScaleInverse}"/>
            </Grid.LayoutTransform>
            <Rectangle Fill="#000000" Opacity="0.75"/>
            <Border Background="{DynamicResource ModalBackground}" BorderBrush="{DynamicResource ModalBorderBrush}" BorderThickness="1"
    Width="460" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="36,30">
                <StackPanel>
                    <TextBlock Text="CHANGE MASTER PASSWORD"
               Foreground="{DynamicResource AppForeground}" FontFamily="/Fonts/#JetBrains Mono"
               FontSize="18"
               HorizontalAlignment="Center"
               TextAlignment="Center"
               TextWrapping="Wrap"
               Margin="0,0,0,20"/>

                    <TextBlock Text="CURRENT PASSWORD" Style="{StaticResource ModalLabel}"/>
                    <PasswordBox x:Name="CurrentMasterPasswordBox"
                 Style="{StaticResource CenteredPasswordBox}"
                 PasswordChanged="CurrentMasterPasswordBox_PasswordChanged"
                 Margin="0,4,0,12"/>

                    <TextBlock Text="NEW PASSWORD" Style="{StaticResource ModalLabel}"/>
                    <PasswordBox x:Name="NewMasterPasswordBox"
                 Style="{StaticResource CenteredPasswordBox}"
                 PasswordChanged="NewMasterPasswordBox_PasswordChanged"
                 Margin="0,4,0,12"/>

                    <TextBlock Text="CONFIRM NEW PASSWORD" Style="{StaticResource ModalLabel}"/>
                    <PasswordBox x:Name="ConfirmMasterPasswordBox"
                 Style="{StaticResource CenteredPasswordBox}"
                 PasswordChanged="ConfirmMasterPasswordBox_PasswordChanged"
                 Margin="0,4,0,12"/>

                    <TextBlock Text="{Binding MasterPasswordErrorMessage}"
               Foreground="#FF4D4D" FontFamily="/Fonts/#JetBrains Mono"
               FontSize="11"
               HorizontalAlignment="Center"
               TextAlignment="Center"
               TextWrapping="Wrap"
               Margin="0,0,0,16"
               Visibility="{Binding MasterPasswordErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="CHANGE"
                Width="130" Style="{StaticResource SailockButton}"
                Command="{Binding ConfirmChangeMasterPasswordCommand}"
                Margin="0,0,16,0"/>
                        <Button Content="CANCEL"
                Width="130" Style="{StaticResource SailockButton}"
                Command="{Binding CancelChangeMasterPasswordCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
