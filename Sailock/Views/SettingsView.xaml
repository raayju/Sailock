<UserControl x:Class="Sailock.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Sailock.Views"
             Background="{DynamicResource AppBackground}">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled"
              Style="{StaticResource SailockScrollViewer}">

            <StackPanel Margin="32,28,32,28">

                <!-- Título -->
                <TextBlock Text="SETTINGS"
                           Foreground="White"
                           FontFamily="/Fonts/#Supermolot Light"
                           FontSize="36"
                           Margin="0,0,0,24"/>

                <!-- SECURITY -->
                <Border BorderBrush="{DynamicResource ContrastBorderBrush}"
                        BorderThickness="{DynamicResource ContrastBorderThickness}"
                        Margin="0,0,0,20">
                    <StackPanel>

                        <TextBlock Text="SECURITY"
                                   Foreground="#444444"
                                   FontFamily="/Fonts/#Supermolot Light"
                                   FontSize="11"
                                   Margin="16,10,16,10"/>

                        <Rectangle Height="1" Fill="{DynamicResource ContrastSeparatorBrush}"/>

                        <!-- Enable 2FA -->
                        <Grid Margin="16,16,16,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="ENABLE 2FA PASSWORD"
                                           Foreground="White"
                                           FontFamily="/Fonts/#Supermolot Light"
                                           FontSize="13"/>
                                <TextBlock Text="Add an extra layer of security by enabling 2FA"
                                           Foreground="#444444"
                                           FontFamily="/Fonts/#Supermolot Light"
                                           FontSize="10"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Width="110"
                                    Style="{StaticResource SailockButton}"
                                    Command="{Binding Enable2FACommand}">
                                <Button.Content>
                                    <TextBlock FontFamily="/Fonts/#Supermolot Light" FontSize="12">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="ENABLE"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Is2FAEnabled}" Value="True">
                                                        <Setter Property="Text" Value="DISABLE"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button.Content>
                            </Button>
                        </Grid>

                        <Rectangle Height="1" Fill="{DynamicResource ContrastSeparatorBrush}"/>

                        <!-- Change Master Password -->
                        <Grid Margin="16,16,16,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="CHANGE MASTER PASSWORD"
                                           Foreground="White"
                                           FontFamily="/Fonts/#Supermolot Light"
                                           FontSize="13"/>
                                <TextBlock Text="Change the master password"
                                           Foreground="#444444"
                                           FontFamily="/Fonts/#Supermolot Light"
                                           FontSize="10"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="CHANGE"
                                    Width="110"
                                    Style="{StaticResource SailockButton}"
                                    Command="{Binding ChangeMasterPassCommand}"/>
                        </Grid>

                        <Rectangle Height="1" Fill="{DynamicResource ContrastSeparatorBrush}"/>

                        <!-- Auto-Lock -->
                        <Grid Margin="16,16,16,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="AUTO-LOCK SESSION"
                                           Foreground="White"
                                           FontFamily="/Fonts/#Supermolot Light"
                                           FontSize="13"/>
                                <TextBlock Text="Automatically log out after 5 minutes of inactivity"
                                           Foreground="#444444"
                                           FontFamily="/Fonts/#Supermolot Light"
                                           FontSize="10"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Width="110"
                                    Style="{StaticResource SailockButton}"
                                    Command="{Binding ToggleAutoLockCommand}">
                                <Button.Content>
                                    <TextBlock FontFamily="/Fonts/#Supermolot Light" FontSize="12">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="ENABLE"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AutoLockEnabled}" Value="True">
                                                        <Setter Property="Text" Value="DISABLE"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button.Content>
                            </Button>
                        </Grid>

                    </StackPanel>
                </Border>

                <!-- ACCESSIBILITY -->
                <Border BorderBrush="{DynamicResource ContrastBorderBrush}"
                        BorderThickness="{DynamicResource ContrastBorderThickness}"
                        Margin="0,0,0,20">
                    <StackPanel>

                        <TextBlock Text="ACCESSIBILITY"
                                   Foreground="#444444"
                                   FontFamily="/Fonts/#Supermolot Light"
                                   FontSize="11"
                                   Margin="16,10,16,10"/>

                        <Rectangle Height="1" Fill="{DynamicResource ContrastSeparatorBrush}"/>

                        <!-- Theme -->
                        <Grid Margin="16,16,16,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="THEME"
                                           Foreground="White"
                                           FontFamily="/Fonts/#Supermolot Light"
                                           FontSize="13"/>
                                <TextBlock Text="Switch the app theme between light and dark mode"
                                           Foreground="#444444"
                                           FontFamily="/Fonts/#Supermolot Light"
                                           FontSize="10"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <CheckBox Content="LIGHT"
                                          IsChecked="{Binding IsDarkTheme, Converter={StaticResource InverseBoolConverter}}"
                                          Style="{StaticResource SailockCheckBox}"
                                          Margin="0,0,16,0"/>
                                <CheckBox Content="DARK"
                                          IsChecked="{Binding IsDarkTheme}"
                                          Style="{StaticResource SailockCheckBox}"/>
                            </StackPanel>
                        </Grid>

                        <Rectangle Height="1" Fill="{DynamicResource ContrastSeparatorBrush}"/>

                        <!-- Contrast -->
                        <Grid Margin="16,16,16,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="CONTRAST"
                                           Foreground="White"
                                           FontFamily="/Fonts/#Supermolot Light"
                                           FontSize="13"/>
                                <TextBlock Text="Improve the visibility of text and buttons"
                                           Foreground="#444444"
                                           FontFamily="/Fonts/#Supermolot Light"
                                           FontSize="10"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <CheckBox Content="ON"
                                          IsChecked="{Binding IsHighContrast}"
                                          Style="{StaticResource SailockCheckBox}"
                                          Margin="0,0,16,0"/>
                                <CheckBox Content="OFF"
                                          IsChecked="{Binding IsHighContrast, Converter={StaticResource InverseBoolConverter}}"
                                          Style="{StaticResource SailockCheckBox}"/>
                            </StackPanel>
                        </Grid>

                        <Rectangle Height="1" Fill="{DynamicResource ContrastSeparatorBrush}"/>

                        <!-- Text Size -->
                        <Grid Margin="16,16,16,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="TEXT SIZE"
                                           Foreground="White"
                                           FontFamily="/Fonts/#Supermolot Light"
                                           FontSize="13"/>
                                <TextBlock Text="Increase or decrease the font size"
                                           Foreground="#444444"
                                           FontFamily="/Fonts/#Supermolot Light"
                                           FontSize="10"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1"
                                      SelectedItem="{Binding SelectedTextSize, Mode=TwoWay}"
                                      Width="160"
                                      Style="{StaticResource SailockComboBox}"
                                      ItemsSource="{x:Static local:SettingsView.TextSizeOptions}"/>
                        </Grid>

                        <Rectangle Height="1" Fill="{DynamicResource ContrastSeparatorBrush}"/>

                        <!-- Language -->
                        <Grid Margin="16,16,16,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="LANGUAGE"
                                           Foreground="White"
                                           FontFamily="/Fonts/#Supermolot Light"
                                           FontSize="13"/>
                                <TextBlock Text="Choose your preferred language"
                                           Foreground="#444444"
                                           FontFamily="/Fonts/#Supermolot Light"
                                           FontSize="10"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1"
                                      SelectedItem="{Binding SelectedLanguage}"
                                      Width="160"
                                      Style="{StaticResource SailockComboBox}">
                                <ComboBoxItem Content="English"/>
                                <ComboBoxItem Content="Español"/>
                                <ComboBoxItem Content="Français"/>
                                <ComboBoxItem Content="Deutsch"/>
                            </ComboBox>
                        </Grid>

                    </StackPanel>
                </Border>

                <!-- DATA MANAGEMENT -->
                <Border BorderBrush="{DynamicResource ContrastBorderBrush}"
                        BorderThickness="{DynamicResource ContrastBorderThickness}"
                        Margin="0,0,0,20">
                    <StackPanel>

                        <TextBlock Text="DATA MANAGEMENT"
                                   Foreground="#444444"
                                   FontFamily="/Fonts/#Supermolot Light"
                                   FontSize="11"
                                   Margin="16,10,16,10"/>

                        <Rectangle Height="1" Fill="{DynamicResource ContrastSeparatorBrush}"/>

                        <!-- Status message -->
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="#00FF41"
                                   FontFamily="/Fonts/#Supermolot Light"
                                   FontSize="11"
                                   Margin="16,12,16,0"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding StatusMessage,
                                                Converter={StaticResource NullToVisibilityConverter}}"/>

                        <!-- Import -->
                        <Grid Margin="16,16,16,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="IMPORT"
                                           Foreground="White"
                                           FontFamily="/Fonts/#Supermolot Light"
                                           FontSize="13"/>
                                <TextBlock Text="Import a .slock file"
                                           Foreground="#444444"
                                           FontFamily="/Fonts/#Supermolot Light"
                                           FontSize="10"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="IMPORT"
                                    Width="110"
                                    Style="{StaticResource SailockButton}"
                                    Command="{Binding ImportCommand}"/>
                        </Grid>

                        <Rectangle Height="1" Fill="{DynamicResource ContrastSeparatorBrush}"/>

                        <!-- Export -->
                        <Grid Margin="16,16,16,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="EXPORT"
                                           Foreground="White"
                                           FontFamily="/Fonts/#Supermolot Light"
                                           FontSize="13"/>
                                <TextBlock Text="Export your data as a backup or import it on a new device"
                                           Foreground="#444444"
                                           FontFamily="/Fonts/#Supermolot Light"
                                           FontSize="10"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="EXPORT"
                                    Width="110"
                                    Style="{StaticResource SailockButton}"
                                    Command="{Binding ExportCommand}"/>
                        </Grid>

                    </StackPanel>
                </Border>

                <!-- DANGER ZONE -->
                <Border BorderBrush="#2A0000"
                        BorderThickness="1"
                        Margin="0,0,0,20">
                    <StackPanel>

                        <TextBlock Text="DANGER ZONE"
                                   Foreground="#663333"
                                   FontFamily="/Fonts/#Supermolot Light"
                                   FontSize="11"
                                   Margin="16,10,16,10"/>

                        <Rectangle Height="1" Fill="#2A0000"/>

                        <!-- Delete All Data -->
                        <Grid Margin="16,16,16,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="DELETE ALL DATA"
                                           Foreground="#FF4D4D"
                                           FontFamily="/Fonts/#Supermolot Light"
                                           FontSize="13"/>
                                <TextBlock Text="Delete all stored data. This action cannot be undone."
                                           Foreground="#663333"
                                           FontFamily="/Fonts/#Supermolot Light"
                                           FontSize="10"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="DELETE"
                                    Width="110"
                                    Style="{StaticResource SailockButton_Danger}"
                                    Command="{Binding OpenDeleteModalCommand}"/>
                        </Grid>

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Modal Delete All -->
        <Grid Visibility="{Binding IsDeleteModalOpen,
                           Converter={StaticResource BoolToVisibilityConverter}}">
            <Rectangle Fill="#000000" Opacity="0.75"/>
            <Border Background="#111111"
                    BorderBrush="#FF4D4D"
                    BorderThickness="1"
                    Width="460"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="36,30">
                <StackPanel>
                    <TextBlock Text="DELETE ALL DATA"
                               Foreground="White"
                               FontFamily="/Fonts/#Supermolot Light"
                               FontSize="22"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>
                    <TextBlock Text="THIS ACTION CANNOT BE UNDONE"
                               Foreground="#FF4D4D"
                               FontFamily="/Fonts/#Supermolot Light"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>
                    <TextBlock Text="¿Are you sure you want to delete all your data?"
                               Foreground="#888888"
                               FontFamily="/Fonts/#Supermolot Light"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,0,0,28"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="DELETE"
                                Width="120"
                                Style="{StaticResource SailockButton_Danger}"
                                Command="{Binding ConfirmDeleteCommand}"
                                Margin="0,0,16,0"/>
                        <Button Content="CANCEL"
                                Width="120"
                                Style="{StaticResource SailockButton}"
                                Command="{Binding CancelDeleteCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            
        </Grid>

        <!-- Modal confirmación desactivar 2FA -->
        <Grid Visibility="{Binding IsDisable2FAModalOpen,
                   Converter={StaticResource BoolToVisibilityConverter}}">
            <Rectangle Fill="#000000" Opacity="0.75"/>
            <Border Background="#111111"
            BorderBrush="#00ab26"
            BorderThickness="1"
            Width="420"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Padding="36,30">
                <StackPanel>
                    <TextBlock Text="DESACTIVAR 2FA"
                       Foreground="White"
                       FontFamily="/Fonts/#Supermolot Light"
                       FontSize="22"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,12"/>
                    <TextBlock Text="Al desactivar el 2FA tu cuenta será menos segura."
                       Foreground="#888888"
                       FontFamily="/Fonts/#Supermolot Light"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,0,0,20"/>
                    <TextBlock Text="NOTA: Los codigos actuales dejarán de funcionar."
                       Foreground="#FF4D4D"
                       FontFamily="/Fonts/#Supermolot Light"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,0,0,28"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="DESACTIVAR"
                        Width="130"
                        Style="{StaticResource SailockButton_Danger}"
                        Command="{Binding ConfirmDisable2FACommand}"
                        Margin="0,0,16,0"/>
                        <Button Content="CANCELAR"
                        Width="130"
                        Style="{StaticResource SailockButton}"
                        Command="{Binding CancelDisable2FACommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>