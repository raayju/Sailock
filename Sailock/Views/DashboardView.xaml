<UserControl x:Class="Sailock.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#000000">

    <Grid>
        <!-- Contenido principal -->
        <Grid Margin="32,28,32,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Título -->
            <TextBlock Grid.Row="0"
                       Text="{DynamicResource Dashboard_Title}"
                       Foreground="White"
                       FontFamily="/Fonts/#Supermolot Light"
                       FontSize="36"
                       Margin="0,0,0,24"/>

            <!-- Barra búsqueda + Add New -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Background="#0D0D0D"
                         Foreground="#00FF41"
                         CaretBrush="#00FF41"
                         BorderBrush="#1A1A1A"
                         BorderThickness="1"
                         Height="38"
                         Padding="14,0"
                         VerticalContentAlignment="Center"
                         FontFamily="/Fonts/#Supermolot Light"
                         FontSize="12"
                         Margin="0,0,12,0">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <ScrollViewer x:Name="PART_ContentHost"
                                                          VerticalAlignment="Center"
                                                          Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <Button Grid.Column="1"
                        Content="{DynamicResource Dashboard_AddNew}"
                        Width="120"
                        Style="{StaticResource SailockButton}"
                        Command="{Binding OpenAddModalCommand}"/>
            </Grid>

            <!-- Cabecera columnas -->
            <Grid Grid.Row="2" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{DynamicResource Dashboard_ColTitle}"
                           Foreground="#444444" FontFamily="/Fonts/#Supermolot Light" FontSize="11" Margin="4,0,0,0"/>
                <TextBlock Grid.Column="1" Text="{DynamicResource Dashboard_ColData}"
                           Foreground="#444444" FontFamily="/Fonts/#Supermolot Light" FontSize="11"/>
                <TextBlock Grid.Column="2" Text="{DynamicResource Dashboard_ColValue}"
                           Foreground="#444444" FontFamily="/Fonts/#Supermolot Light" FontSize="11"/>
                <TextBlock Grid.Column="3" Text="{DynamicResource Dashboard_ColOptions}"
                           Foreground="#444444" FontFamily="/Fonts/#Supermolot Light" FontSize="11" HorizontalAlignment="Right"/>
            </Grid>

            <Rectangle Grid.Row="2" Height="1" Fill="#1A1A1A" VerticalAlignment="Bottom" Margin="0,0,0,-1"/>

            <!-- Lista -->
            <ScrollViewer Grid.Row="3"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Entries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid MinHeight="52">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding Title}"
                                           Foreground="White" FontFamily="/Fonts/#Supermolot Light"
                                           FontSize="13" VerticalAlignment="Center" Margin="4,0,0,0"/>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource Dashboard_FieldEmail}"
                                               Foreground="#555555" FontFamily="/Fonts/#Supermolot Light" FontSize="11"
                                               Visibility="{Binding Email, Converter={StaticResource NullToVisibilityConverter}}"/>
                                    <TextBlock Text="{DynamicResource Dashboard_FieldUsername}"
                                               Foreground="#555555" FontFamily="/Fonts/#Supermolot Light" FontSize="11"
                                               Visibility="{Binding Username, Converter={StaticResource NullToVisibilityConverter}}"/>
                                    <TextBlock Text="{DynamicResource Dashboard_FieldPassword}"
                                               Foreground="#555555" FontFamily="/Fonts/#Supermolot Light" FontSize="11"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Email}"
                                               Foreground="#00FF41" FontFamily="/Fonts/#Supermolot Light" FontSize="11"
                                               Visibility="{Binding Email, Converter={StaticResource NullToVisibilityConverter}}"/>
                                    <TextBlock Text="{Binding Username}"
                                               Foreground="#00FF41" FontFamily="/Fonts/#Supermolot Light" FontSize="11"
                                               Visibility="{Binding Username, Converter={StaticResource NullToVisibilityConverter}}"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="••••••••••" Foreground="#00FF41" FontSize="11"
                                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <Button Content="{DynamicResource Dashboard_CopyPassword}"
                                                Foreground="#00ab26" Background="Transparent" BorderThickness="0"
                                                FontFamily="/Fonts/#Supermolot Light" FontSize="11" Cursor="Hand"
                                                Command="{Binding DataContext.CopyPasswordCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </StackPanel>

                                <Button Grid.Column="3"
                                        Content="{DynamicResource Dashboard_Edit}"
                                        Foreground="#00FF41" Background="Transparent" BorderThickness="0"
                                        FontFamily="/Fonts/#Supermolot Light" FontSize="12" Cursor="Hand"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Command="{Binding DataContext.OpenEditModalCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"/>

                                <Rectangle Grid.ColumnSpan="4" Height="1" Fill="#111111" VerticalAlignment="Bottom"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- ═══════════════════════ MODAL ADD NEW ═══════════════════════ -->
        <Grid Visibility="{Binding IsAddModalOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Rectangle Fill="#000000" Opacity="0.7"/>
            <Border Background="#111111" BorderBrush="#00ab26" BorderThickness="1"
                    Width="460" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="36,30">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Modal_AddNew_Title}"
                               Foreground="White" FontFamily="/Fonts/#Supermolot Light"
                               FontSize="22" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <TextBlock Text="{DynamicResource Modal_FieldTitle}" Style="{StaticResource ModalLabel}"/>
                    <TextBox Text="{Binding EditingEntry.Title, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModalTextBox}" Margin="0,4,0,12"/>

                    <TextBlock Text="{DynamicResource Modal_FieldCategory}" Style="{StaticResource ModalLabel}"/>
                    <TextBox Text="{Binding EditingEntry.Category, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModalTextBox}" Margin="0,4,0,12"/>

                    <TextBlock Text="{DynamicResource Modal_FieldEmail}" Style="{StaticResource ModalLabel}"/>
                    <TextBox Text="{Binding EditingEntry.Email, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModalTextBox}" Margin="0,4,0,12"/>

                    <TextBlock Text="{DynamicResource Modal_FieldUsername}" Style="{StaticResource ModalLabel}"/>
                    <TextBox Text="{Binding EditingEntry.Username, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModalTextBox}" Margin="0,4,0,12"/>

                    <TextBlock Text="{DynamicResource Modal_FieldPassword}" Style="{StaticResource ModalLabel}"/>
                    <Grid Margin="0,4,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="{Binding EditingEntry.Password, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#0D0D0D" Foreground="White" CaretBrush="#00FF41"
                                 BorderBrush="#333333" BorderThickness="1" Height="34"
                                 FontFamily="/Fonts/#Supermolot Light" FontSize="12"
                                 Padding="10,0" VerticalContentAlignment="Center">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}">
                                                    <ScrollViewer x:Name="PART_ContentHost"
                                                                  VerticalAlignment="Center"
                                                                  Margin="{TemplateBinding Padding}"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPasswordVisible}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <PasswordBox x:Name="AddPasswordBox"
                                     Grid.Column="0"
                                     PasswordChanged="EditPasswordBox_PasswordChanged"
                                     Background="#0D0D0D" Foreground="#00FF41" CaretBrush="#00FF41"
                                     BorderBrush="#333333" BorderThickness="1" Height="34"
                                     FontFamily="/Fonts/#Supermolot Light" FontSize="14">
                            <PasswordBox.Style>
                                <Style TargetType="PasswordBox">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="PasswordBox">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}">
                                                    <ScrollViewer x:Name="PART_ContentHost"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"
                                                                  Margin="10,0"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPasswordVisible}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </PasswordBox.Style>
                        </PasswordBox>

                        <Button Grid.Column="1" Content="👁" Background="Transparent" BorderThickness="0"
                                Foreground="#444444" FontSize="14" Cursor="Hand"
                                VerticalAlignment="Center" HorizontalAlignment="Center"
                                Command="{Binding TogglePasswordVisibilityCommand}"/>
                    </Grid>

                    <TextBlock Text="{DynamicResource Modal_FieldNote}" Style="{StaticResource ModalLabel}"/>
                    <TextBox Text="{Binding EditingEntry.Note, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModalTextBox}" Height="80"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalContentAlignment="Top" Margin="0,4,0,24"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="{DynamicResource Modal_Save}"
                                Width="120"
                                Style="{StaticResource SailockButton}"
                                Command="{Binding SaveNewEntryCommand}"
                                Margin="0,0,16,0"/>
                        <Button Content="{DynamicResource Modal_Cancel}"
                                Width="120"
                                Style="{StaticResource SailockButton}"
                                Command="{Binding CancelAddCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══════════════════════ MODAL EDIT ═══════════════════════ -->
        <Grid Visibility="{Binding IsEditModalOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Rectangle Fill="#000000" Opacity="0.7"/>
            <Border Background="#111111" BorderBrush="#00ab26" BorderThickness="1"
                    Width="460" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="36,30">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Modal_Edit_Title}"
                               Foreground="White" FontFamily="/Fonts/#Supermolot Light"
                               FontSize="22" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <TextBlock Text="{DynamicResource Modal_FieldTitle}" Style="{StaticResource ModalLabel}"/>
                    <TextBox Text="{Binding EditingEntry.Title, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModalTextBox}" Margin="0,4,0,12"/>

                    <TextBlock Text="{DynamicResource Modal_FieldCategory}" Style="{StaticResource ModalLabel}"/>
                    <TextBox Text="{Binding EditingEntry.Category, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModalTextBox}" Margin="0,4,0,12"/>

                    <TextBlock Text="{DynamicResource Modal_FieldEmail}" Style="{StaticResource ModalLabel}"/>
                    <TextBox Text="{Binding EditingEntry.Email, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModalTextBox}" Margin="0,4,0,12"/>

                    <TextBlock Text="{DynamicResource Modal_FieldUsername}" Style="{StaticResource ModalLabel}"/>
                    <TextBox Text="{Binding EditingEntry.Username, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModalTextBox}" Margin="0,4,0,12"/>

                    <TextBlock Text="{DynamicResource Modal_FieldPassword}" Style="{StaticResource ModalLabel}"/>
                    <Grid Margin="0,4,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="{Binding EditingEntry.Password, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#0D0D0D" Foreground="White" CaretBrush="#00FF41"
                                 BorderBrush="#333333" BorderThickness="1" Height="34"
                                 FontFamily="/Fonts/#Supermolot Light" FontSize="12"
                                 Padding="10,0" VerticalContentAlignment="Center">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}">
                                                    <ScrollViewer x:Name="PART_ContentHost"
                                                                  VerticalAlignment="Center"
                                                                  Margin="{TemplateBinding Padding}"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPasswordVisible}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <PasswordBox x:Name="EditPasswordBoxModal"
                                     Grid.Column="0"
                                     PasswordChanged="EditPasswordBox_PasswordChanged"
                                     Background="#0D0D0D" Foreground="#00FF41" CaretBrush="#00FF41"
                                     BorderBrush="#333333" BorderThickness="1" Height="34"
                                     FontFamily="/Fonts/#Supermolot Light" FontSize="14">
                            <PasswordBox.Style>
                                <Style TargetType="PasswordBox">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="PasswordBox">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}">
                                                    <ScrollViewer x:Name="PART_ContentHost"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"
                                                                  Margin="10,0"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPasswordVisible}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </PasswordBox.Style>
                        </PasswordBox>

                        <Button Grid.Column="1" Content="👁" Background="Transparent" BorderThickness="0"
                                Foreground="#444444" FontSize="14" Cursor="Hand"
                                VerticalAlignment="Center" HorizontalAlignment="Center"
                                Command="{Binding TogglePasswordVisibilityCommand}"/>
                    </Grid>

                    <TextBlock Text="{DynamicResource Modal_FieldNote}" Style="{StaticResource ModalLabel}"/>
                    <TextBox Text="{Binding EditingEntry.Note, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModalTextBox}" Height="80"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalContentAlignment="Top" Margin="0,4,0,24"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="{DynamicResource Modal_SaveChanges}"
                                Width="110"
                                Style="{StaticResource SailockButton}"
                                Command="{Binding SaveEditCommand}"
                                Margin="0,0,12,0"
                                Visibility="{Binding HasEditChanges, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        <Button Content="{DynamicResource Modal_Delete}"
                                Width="110"
                                Style="{StaticResource SailockButton_Danger}"
                                Command="{Binding DeleteEntryCommand}"
                                Margin="0,0,12,0"/>
                        <Button Content="{DynamicResource Modal_Cancel}"
                                Width="110"
                                Style="{StaticResource SailockButton}"
                                Command="{Binding CancelEditCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══════════════════════ MODAL MASTER PASSWORD ═══════════════════════ -->
        <Grid Visibility="{Binding IsMasterPasswordModalOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Rectangle Fill="#000000" Opacity="0.75"/>
            <Border Background="#111111" BorderBrush="#00ab26" BorderThickness="1"
                    Width="380" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="36,30">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Modal_MasterPass_Title}"
                               Foreground="White" FontFamily="/Fonts/#Supermolot Light"
                               FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="{DynamicResource Modal_MasterPass_Label}"
                               Foreground="#666666" FontFamily="/Fonts/#Supermolot Light"
                               FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <PasswordBox x:Name="MasterPasswordVerify"
                                 Style="{StaticResource CenteredPasswordBox}"
                                 PasswordChanged="MasterPasswordVerify_PasswordChanged"
                                 KeyDown="MasterPasswordVerify_KeyDown"
                                 Margin="0,0,0,8"/>

                    <TextBlock Text="{DynamicResource Modal_MasterPass_Error}"
                               Foreground="#FF4D4D" FontFamily="/Fonts/#Supermolot Light"
                               FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,16"
                               Visibility="{Binding MasterPasswordFailed, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="{DynamicResource Modal_Confirm}"
                                Width="130" Style="{StaticResource SailockButton}"
                                Command="{Binding ConfirmMasterPasswordCommand}"
                                Margin="0,0,16,0"/>
                        <Button Content="{DynamicResource Modal_Cancel}"
                                Width="130" Style="{StaticResource SailockButton}"
                                Command="{Binding CancelMasterPasswordCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>