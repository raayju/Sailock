<UserControl x:Class="Sailock.Views.GeneratorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#000000">

    <Grid Margin="32,28,32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0"
                   Text="{DynamicResource Generator_Title}"
                   Foreground="White"
                   FontFamily="/Fonts/#Supermolot Light"
                   FontSize="36"
                   Margin="0,0,0,24"/>

        <!-- Contraseña generada + COPY -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#0D0D0D"
                    BorderBrush="#1A1A1A"
                    BorderThickness="1"
                    Height="38"
                    Margin="0,0,12,0">
                <Grid>
                    <TextBlock Text="{DynamicResource Generator_Placeholder}"
                               Foreground="#2A2A2A"
                               FontFamily="/Fonts/#Supermolot Light"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Padding="14,0"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding GeneratedPassword}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding GeneratedPassword}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding GeneratedPassword}"
                               Foreground="#00FF41"
                               FontFamily="/Fonts/#Supermolot Light"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Padding="14,0"/>
                </Grid>
            </Border>

            <Button Grid.Column="1"
                    Content="{DynamicResource Generator_Copy}"
                    Width="100"
                    Style="{StaticResource SailockButton}"
                    Command="{Binding CopyCommand}"/>
        </Grid>

        <!-- Slider longitud -->
        <StackPanel Grid.Row="2" Margin="0,0,0,20">
            <TextBlock Foreground="White"
                       FontFamily="/Fonts/#Supermolot Light"
                       FontSize="12"
                       Margin="0,0,0,8">
                <Run Text="{DynamicResource Generator_LengthPrefix}"/>
                <Run Text="{Binding Length}"/>
                <Run Text="{DynamicResource Generator_LengthSuffix}"/>
            </TextBlock>

            <Slider x:Name="LengthSlider"
                    Minimum="4" Maximum="64"
                    Value="{Binding Length, Mode=TwoWay}"
                    TickFrequency="1"
                    IsSnapToTickEnabled="True"
                    Foreground="#00FF41"
                    Background="#1A1A1A"
                    Style="{StaticResource SailockSlider}"/>
        </StackPanel>

        <!-- Checkboxes -->
        <Grid Grid.Row="3" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <CheckBox Grid.Column="0" Content="{DynamicResource Generator_Uppercase}"
                      IsChecked="{Binding UseUppercase}" Style="{StaticResource SailockCheckBox}"/>
            <CheckBox Grid.Column="1" Content="{DynamicResource Generator_Lowercase}"
                      IsChecked="{Binding UseLowercase}" Style="{StaticResource SailockCheckBox}"/>
            <CheckBox Grid.Column="2" Content="{DynamicResource Generator_Numbers}"
                      IsChecked="{Binding UseNumbers}"   Style="{StaticResource SailockCheckBox}"/>
            <CheckBox Grid.Column="3" Content="{DynamicResource Generator_Symbols}"
                      IsChecked="{Binding UseSymbols}"   Style="{StaticResource SailockCheckBox}"/>
        </Grid>

        <!-- Toggles -->
        <Grid Grid.Row="4" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="{DynamicResource Generator_RepeatChars}"
                       Foreground="White"
                       FontFamily="/Fonts/#Supermolot Light"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Margin="0,0,16,0"/>
            <ToggleButton Grid.Column="1"
                          IsChecked="{Binding AllowRepeat}"
                          Style="{StaticResource SailockToggle}"/>
            <TextBlock Grid.Column="3"
                       Text="{DynamicResource Generator_SequentialChars}"
                       Foreground="White"
                       FontFamily="/Fonts/#Supermolot Light"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Margin="0,0,16,0"/>
            <ToggleButton Grid.Column="4"
                          IsChecked="{Binding AllowSequential}"
                          Style="{StaticResource SailockToggle}"/>
        </Grid>

        <!-- Excluir caracteres -->
        <Grid Grid.Row="5" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="{DynamicResource Generator_ExcludeChars}"
                       Foreground="White"
                       FontFamily="/Fonts/#Supermolot Light"
                       FontSize="12"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="1"
                     Text="{Binding ExcludeCharacters, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ModalTextBoxWithPlaceholder}"
                     Height="38" TextChanged="TextBox_TextChanged"/>
        </Grid>

        <!-- Start with -->
        <Grid Grid.Row="6" Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="{DynamicResource Generator_StartWith}"
                       Foreground="White"
                       FontFamily="/Fonts/#Supermolot Light"
                       FontSize="12"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="1"
                     Text="{Binding StartWith, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ModalTextBoxWithPlaceholder}"
                     Width="160" Height="38"/>
        </Grid>

        <!-- Botón Generate -->
        <Button Grid.Row="8"
                Content="{DynamicResource Generator_Generate}"
                Width="160"
                HorizontalAlignment="Left"
                Style="{StaticResource SailockButton}"
                Command="{Binding GenerateCommand}"
                Margin="0,20,0,0"/>
    </Grid>
</UserControl>